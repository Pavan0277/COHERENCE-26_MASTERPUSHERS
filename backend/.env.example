# Copy this file to .env and fill in the values.
# Never commit .env — it is in .gitignore.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000                          # Render overrides this automatically

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGO_DB_NAME=masterpushers

# ── Auth / JWT ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_string
REFRESH_TOKEN_EXPIRY=10d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ── Redis (BullMQ delayed steps) ─────────────────────────────────────────────
# Leave blank to run without Redis (delayed workflow steps will be disabled)
REDIS_URL=redis://localhost:6379

# ── Backend public URL (used for VAPI webhooks) ───────────────────────────────
BACKEND_URL=https://masterpushers-backend.onrender.com

# ── VAPI (AI voice calls) ─────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Sarvam AI ─────────────────────────────────────────────────────────────────
SARVAM_API_KEY=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
